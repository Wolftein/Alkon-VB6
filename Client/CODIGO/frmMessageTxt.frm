Attribute VB_Name = "frmMessageTxt"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
Option Explicit

Private clsFormulario As clsFormMovementManager

Private cBotonGuardar As clsGraphicalButton
Private cBotonCancelar As clsGraphicalButton

Public LastButtonPressed As clsGraphicalButton

Private Sub Form_Load()
    Dim I As Long
On Error GoTo ErrHandler
  
    
    ' Handles Form movement (drag and drop).
    Set clsFormulario = New clsFormMovementManager
    clsFormulario.Initialize Me
    
    For I = 0 To 9
        messageTxt(I) = CustomMessages.Message(I)
    Next I

    Me.Picture = LoadPicture(DirInterfaces & SELECTED_UI & "VentanaMensajesPersonalizados.jpg")
    
    Call LoadButtons
    
    Call modCustomCursors.SetFormCursorDefault(Me)
    
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub Form_Load de frmMessageTxt.frm")
End Sub

Private Sub LoadButtons()
On Error GoTo ErrHandler
  
    Dim GrhPath As String
    
    GrhPath = DirInterfaces & SELECTED_UI
    
    Set cBotonGuardar = New clsGraphicalButton
    Set cBotonCancelar = New clsGraphicalButton
    
    Set LastButtonPressed = New clsGraphicalButton

    Call cBotonGuardar.Initialize(imgGuardar, GrhPath & "BotonMensajesGuardar.jpg", _
                                                GrhPath & "BotonMensajesGuardarRollover.jpg", _
                                                GrhPath & "BotonMensajesGuardarClick.jpg", Me)
                                                
    Call cBotonCancelar.Initialize(imgCancelar, GrhPath & "BotonMensajesSalir.jpg", _
                                                GrhPath & "BotonMensajesSalirRollover.jpg", _
                                                GrhPath & "BotonMensajesSalirClick.jpg", Me)
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub LoadButtons de frmMessageTxt.frm")
End Sub

Private Sub Form_MouseMove(Button As Integer, Shift As Integer, X As Single, Y As Single)
    LastButtonPressed.ToggleToNormal
End Sub

Private Sub imgCancelar_Click()
    CerrarVentana
End Sub

Private Sub Form_KeyDown(KeyCode As Integer, Shift As Integer)
    If KeyCode = vbKeyEscape Then CerrarVentana
End Sub

Private Sub CerrarVentana()
On Error GoTo ErrHandler
  
    Unload Me
    If frmMain.Visible Then frmMain.SetFocus
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub CerrarVentana de frmMessageTxt.frm")
End Sub

Private Sub imgGuardar_Click()
On Error GoTo ErrHandler
    Dim I As Long
    
    For I = 0 To 9
        CustomMessages.Message(I) = messageTxt(I)
    Next I
    
    CerrarVentana
Exit Sub

ErrHandler:
    'Did detected an invalid message??
    If Err.Number = CustomMessages.InvalidMessageErrCode Then
        Call MsgBox("El Mensaje " & CStr(I + 1) & " es inválido. Modifiquelo por favor.")
    End If

End Sub

Private Sub messageTxt_MouseMove(Index As Integer, Button As Integer, Shift As Integer, X As Single, Y As Single)
    LastButtonPressed.ToggleToNormal
End Sub

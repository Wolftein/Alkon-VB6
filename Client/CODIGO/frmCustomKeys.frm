Private Sub imgGuardar_Click()

On Error GoTo ErrHandler
  
    Dim I As Long
    Dim sMsg As String
    
    For I = 1 To CustomKeys.KeyCount
        If LenB(Text1(I).text) = 0 Then
            Call MsgBox("Hay una o más teclas no válidas, por favor verifique.", vbCritical Or vbOKOnly Or vbApplicationModal Or vbDefaultButton1, "Argentum Online")
            Exit Sub
        End If
    Next I
    
    CustomKeys.CurrentConfig = SelectedConfig
    
    If SelectedConfig <> InitialConfig Then
        sMsg = "¡Se ha cargado la configuración "
        If SelectedConfig = 0 Then
            sMsg = sMsg & "default"
        Else
            sMsg = sMsg & "personalizada número " & CStr(SelectedConfig)
        End If
        sMsg = sMsg & "!"
        
        Call ShowConsoleMsg(sMsg, 255, 255, 255, True)
    End If
    
    Unload Me
    If frmMain.Visible Then frmMain.SetFocus
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub imgGuardar_Click de frmCustomKeys.frm")
End Sub

Private Sub TabClick(ByVal Index As Integer)
On Error GoTo ErrHandler
  

    Select Case CurrentTab
        Case 0
            Call cBotonTabDefault.EnableButton(True)
        Case 1
            Call cBotonTab1.EnableButton(True)
        Case 2
            Call cBotonTab2.EnableButton(True)
        Case 3
            Call cBotonTab3.EnableButton(True)
        Case 4
            Call cBotonTab4.EnableButton(True)
        Case 5
            Call cBotonTab5.EnableButton(True)
        Case 6
            Call cBotonTab6.EnableButton(True)
        Case 7
            Call cBotonTab7.EnableButton(True)
        Case 8
            Call cBotonTab8.EnableButton(True)
        Case 9
            Call cBotonTab9.EnableButton(True)
    End Select
    
    CustomKeys.CurrentConfig = Index
    CurrentTab = Index

    Call ShowConfig
    
    If SelectedConfig = Index Then
        imgTic.Picture = cBotonTac
    Else
        imgTic.Picture = cBotonTic
    End If

    Call Engine_Audio.PlayInterface(SND_CLICK)

  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub TabClick de frmCustomKeys.frm")
End Sub

Private Sub Text1_KeyDown(Index As Integer, KeyCode As Integer, Shift As Integer)
On Error GoTo ErrHandler
  
    Dim I As Long
    
    ' Can't change default combination
    If CurrentTab = 0 Then Exit Sub
    
    If LenB(CustomKeys.ReadableName(KeyCode)) = 0 Then Exit Sub
    'If key is not valid, we exit
    
    Text1(Index).text = CustomKeys.ReadableName(KeyCode)
    Text1(Index).SelStart = Len(Text1(Index).text)
    
    For I = 1 To CustomKeys.KeyCount
        If I <> Index Then
            If CustomKeys.BindedKey(I) = KeyCode Then
                Text1(Index).text = "" 'If the key is already assigned, simply reject it
                Call Beep 'Alert the user
                KeyCode = 0
                
                Exit Sub
            End If
        End If
    Next I
    
    CustomKeys.BindedKey(Index) = KeyCode
    
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub Text1_KeyDown de frmCustomKeys.frm")
End Sub


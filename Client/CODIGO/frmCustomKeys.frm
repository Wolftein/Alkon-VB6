''
'frmCustomKeys - Allows the user to customize keys.
'Implements class clsCustomKeys
'
'@author Rapsodius
'@date 20070805
'@version 1.0.0
'@see clsCustomKeys

Option Explicit

Private clsFormulario As clsFormMovementManager

Private cBotonGuardar As clsGraphicalButton
Private cBotonDefaultKeys As clsGraphicalButton

Private cBotonTabDefault As clsGraphicalButton
Private cBotonTab1 As clsGraphicalButton
Private cBotonTab2 As clsGraphicalButton
Private cBotonTab3 As clsGraphicalButton
Private cBotonTab4 As clsGraphicalButton
Private cBotonTab5 As clsGraphicalButton
Private cBotonTab6 As clsGraphicalButton
Private cBotonTab7 As clsGraphicalButton
Private cBotonTab8 As clsGraphicalButton
Private cBotonTab9 As clsGraphicalButton

Public LastButtonPressed As clsGraphicalButton

'Index de la configuración que seleccionó como activa
Private SelectedConfig As Byte
Private InitialConfig As Byte
Private CurrentTab As Byte
Private cBotonTic As Picture
Private cBotonTac As Picture

Private Sub Form_Load()
    
    ' Handles Form movement (drag and drop).
On Error GoTo ErrHandler
  
    Set clsFormulario = New clsFormMovementManager
    clsFormulario.Initialize Me
    
    Me.Picture = LoadPicture(DirInterfaces & SELECTED_UI & "VentanaConfigurarTeclas.jpg")
    Set cBotonTic = LoadPicture(DirInterfaces & SELECTED_UI & "BotonDueloAmigosTic.jpg")
    Set cBotonTac = LoadPicture(DirInterfaces & SELECTED_UI & "BotonDueloAmigosTac.jpg")
    
    Call LoadButtons

    Call TabInitialize
    
    Call modCustomCursors.SetFormCursorDefault(Me)
  
  Exit Sub
  
ErrHandler:
  Call LogError("Error" & Err.Number & "(" & Err.Description & ") en Sub Form_Load de frmCustomKeys.frm")
End Sub

Private Sub LoadButtons()
On Error GoTo ErrHandler
  
    Dim GrhPath As String
    
    GrhPath = DirInterfaces & SELECTED_UI

    Set cBotonGuardar = New clsGraphicalButton
    Set cBotonDefaultKeys = New clsGraphicalButton
    Set cBotonTabDefault = New clsGraphicalButton
    Set cBotonTab1 = New clsGraphicalButton
    Set cBotonTab2 = New clsGraphicalButton
    Set cBotonTab3 = New clsGraphicalButton
    Set cBotonTab4 = New clsGraphicalButton
    Set cBotonTab5 = New clsGraphicalButton
    Set cBotonTab6 = New clsGraphicalButton
    Set cBotonTab7 = New clsGraphicalButton
    Set cBotonTab8 = New clsGraphicalButton
    Set cBotonTab9 = New clsGraphicalButton
    
    Set LastButtonPressed = New clsGraphicalButton
    
    
    Call cBotonGuardar.Initialize(imgGuardar, GrhPath & "BotonConfigGuardar.jpg", _
                                    GrhPath & "BotonConfigGuardarRollover.jpg", _
                                    GrhPath & "BotonConfigGuardarClick.jpg", Me)

    Call cBotonDefaultKeys.Initialize(imgDefaultKeys, GrhPath & "BotonConfigCargarDefault.jpg", _
                                    GrhPath & "BotonConfigCargarDefaultRollover.jpg", _
                                    GrhPath & "BotonConfigCargarDefaultClick.jpg", Me)
                                    
    Call cBotonTabDefault.Initialize(imgTabDefault, GrhPath & "BotonConfigDefault.jpg", _
                                    GrhPath & "BotonConfigDefaultRollover.jpg", _
                                    GrhPath & "BotonConfigDefaultClick.jpg", Me, GrhPath & "BotonConfigDefaultDisabled.jpg")
                                    
    Call cBotonTab1.Initialize(imgTab1, GrhPath & "BotonConfig1.jpg", _
                                    GrhPath & "BotonConfig1Rollover.jpg", _
                                    GrhPath & "BotonConfig1Click.jpg", Me, GrhPath & "BotonConfig1Disabled.jpg")
                                    
    Call cBotonTab2.Initialize(imgTab2, GrhPath & "BotonConfig2.jpg", _
                                    GrhPath & "BotonConfig2Rollover.jpg", _
                                    GrhPath & "BotonConfig2Click.jpg", Me, GrhPath & "BotonConfig2Disabled.jpg")
                                    
    Call cBotonTab3.Initialize(imgTab3, GrhPath & "BotonConfig3.jpg", _
                                    GrhPath & "BotonConfig3Rollover.jpg", _
                                    GrhPath & "BotonConfig3Click.jpg", Me, GrhPath & "BotonConfig3Disabled.jpg")
                                    
    Call cBotonTab4.Initialize(imgTab4, GrhPath & "BotonConfig4.jpg", _
                                    GrhPath & "BotonConfig4Rollover.jpg", _
                                    GrhPath & "BotonConfig4Click.jpg", Me, GrhPath & "BotonConfig4Disabled.jpg")
                                    
    Call cBotonTab5.Initialize(imgTab5, GrhPath & "BotonConfig5.jpg", _
                                    GrhPath & "BotonConfig5Rollover.jpg", _
                                    GrhPath & "BotonConfig5Click.jpg", Me, GrhPath & "BotonConfig5Disabled.jpg")
                                    
    Call cBotonTab6.Initialize(imgTab6, GrhPath & "BotonConfig6.jpg", _
